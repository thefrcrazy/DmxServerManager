{
  "name": "dmx-server-manager-frontend",
  "private": true,
  "version": "1.1.5",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "refresh:api-schema": "bun run scripts/openapi.ts refresh",
    "generate:api": "bun run scripts/openapi.ts generate",
    "check:api": "bun run generate:api && git diff --exit-code -- openapi.json src/generated/api.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json",
    "test": "bun test tests",
    "test:e2e": "playwright test",
    "capture:visuals": "DMX_CAPTURE_VISUAL_REFERENCES=1 playwright test e2e/visual-references.spec.ts --workers=1",
    "prepare:e2e:real": "bun run build && cargo build --locked --manifest-path ../backend/Cargo.toml",
    "test:e2e:real": "bun run prepare:e2e:real && playwright test --config playwright.real.config.ts",
    "test:e2e:headed": "playwright test --headed",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "1.24.0",
    "monaco-editor": "^0.56.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^25.0.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "openapi-typescript": "7.13.0",
    "sass": "1.101.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4"
  },
  "trustedDependencies": [
    "sass"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "flatted": "3.4.2",
    "js-yaml": "4.3.0",
    "picomatch": "4.0.5"
  }
}
