{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "types": ["node", "@playwright/test"],
        "paths": { "@/*": ["../src/*"] }
    },
    "include": [
        "./**/*.ts",
        "../e2e-real/**/*.ts",
        "../playwright.config.ts",
        "../playwright.real.config.ts"
    ]
}
